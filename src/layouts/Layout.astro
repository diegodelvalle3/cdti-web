---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CDTI Cuernavaca — Centro de Evaluación, Diagnóstico y Terapia Integral',
  description = 'CDTI es un centro en Acapantzingo, Cuernavaca, dedicado a la evaluación, diagnóstico y terapia de lenguaje y psicológica para niñas, niños y adolescentes, con un equipo multidisciplinario y enfoque cognitivo-conductual.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
