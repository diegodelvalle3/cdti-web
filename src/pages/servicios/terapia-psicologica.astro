---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import Footer from '../../components/Footer.astro';

const areas = [
  { title: 'TDAH', text: 'Estrategias para atención, impulsividad y organización dentro y fuera de casa.' },
  { title: 'TOC', text: 'Acompañamiento en pensamientos y conductas repetitivas, a su propio ritmo.' },
  { title: 'Conducta', text: 'Manejo conductual en casa y escuela, en coordinación con la familia.' },
  { title: 'Desarrollo socioemocional', text: 'Herramientas para identificar y regular emociones según la edad.' },
];
---

<Layout
  title="Terapia psicológica — CDTI Cuernavaca"
  description="Terapia psicológica infantil en CDTI Cuernavaca: TDAH, TOC, conducta y desarrollo socioemocional, con enfoque cognitivo-conductual."
>
  <Header />
  <main>
    <PageHero
      eyebrow="Servicios"
      title="Terapia psicológica"
      description="Acompañamiento psicológico para niñez y adolescencia, bajo un enfoque cognitivo-conductual, con intervenciones breves y constantes."
      crumbs={[{ label: 'Inicio', href: '/' }, { label: 'Servicios', href: '/servicios/' }, { label: 'Terapia psicológica' }]}
      variant="teal"
    />

    <section class="section-pad band-white">
      <div class="wrap intro-grid">
        <div>
          <p class="eyebrow">Nuestro enfoque</p>
          <h2>Terapia cognitivo-conductual, sesión a sesión</h2>
          <p class="body-text">
            Nuestras psicólogas trabajan con niñas, niños y adolescentes bajo un
            enfoque cognitivo-conductual, a través de intervenciones breves y
            continuas. Cada plan se ajusta al ritmo del paciente, con monitoreo
            constante del progreso a lo largo del proceso.
          </p>
          <p class="body-text">
            Cuando el caso lo requiere, coordinamos con neurólogos, psiquiatras
            y otros especialistas, para que el tratamiento psicológico se
            sostenga dentro de una visión más amplia del bienestar del paciente.
          </p>
        </div>
        <div class="frame"><span>Foto de una sesión de psicología</span></div>
      </div>
    </section>

    <section class="section-pad band-paper">
      <div class="wrap">
        <p class="eyebrow center">Áreas de atención</p>
        <h2 class="center">Algunos de los temas que acompañamos</h2>
        <div class="areas-grid">
          {areas.map(a => (
            <div class="area-card">
              <h3>{a.title}</h3>
              <p>{a.text}</p>
            </div>
          ))}
        </div>
        <p class="note">
          Cada diagnóstico y plan de tratamiento se define de forma individual
          tras el proceso de evaluación; esta lista es solo orientativa.
        </p>
      </div>
    </section>

    <section class="section-pad band-white">
      <div class="wrap">
        <p class="eyebrow center">Explora otros servicios</p>
        <div class="related">
          <a href="/servicios/evaluacion-y-diagnostico/" class="related-card">
            <h3>Evaluación y diagnóstico →</h3>
          </a>
          <a href="/servicios/terapia-de-lenguaje/" class="related-card">
            <h3>Terapia de lenguaje →</h3>
          </a>
        </div>
      </div>
    </section>

    <CtaBand
      title="¿Hablamos sobre tu caso?"
      text="Agenda una primera evaluación psicológica y diseñemos juntos un plan de acompañamiento."
    />
  </main>
  <Footer />
</Layout>

<style>
  .center { text-align: center; }
  h2 { font-size: clamp(24px, 3vw, 32px); color: var(--teal-deep); margin-top: 10px; font-family: var(--font-display); }
  h2.center { margin: 12px auto 0; }
  .body-text { margin-top: 16px; color: var(--ink-soft); max-width: 54ch; }
  .intro-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 48px; align-items: center; }
  .frame {
    aspect-ratio: 4/3;
    border-radius: 40px 18px 40px 18px;
    background: var(--teal-mist);
    border: 1px solid var(--line);
    display: flex; align-items: center; justify-content: center;
    text-align: center; color: var(--ink-soft); font-weight: 600; font-size: 14px; padding: 24px;
  }

  .areas-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 48px; }
  .area-card { background: var(--card); border: 1px solid var(--line); border-radius: 8px 22px 8px 22px; padding: 24px 20px; }
  .area-card h3 { font-size: 16px; color: var(--clay-deep); }
  .area-card p { margin-top: 8px; font-size: 13.5px; color: var(--ink-soft); line-height: 1.5; }
  .note { margin-top: 28px; text-align: center; font-size: 13px; color: var(--ink-soft); font-style: italic; }

  .related { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 36px; }
  .related-card { background: var(--paper-deep); border-radius: 18px; padding: 22px 24px; font-weight: 700; color: var(--teal-deep); }
  .related-card:hover { background: var(--teal-mist); }

  @media (max-width: 920px) {
    .intro-grid { grid-template-columns: 1fr; }
    .areas-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .areas-grid, .related { grid-template-columns: 1fr; }
  }
</style>
