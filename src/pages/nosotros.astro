---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import Nosotros from '../components/Nosotros.astro';
import Enfoque from '../components/Enfoque.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Quiénes somos — CDTI Cuernavaca"
  description="Conoce al equipo clínico de CDTI en Acapantzingo, Cuernavaca, y nuestro enfoque cognitivo-conductual para evaluación, diagnóstico y terapia infantil."
>
  <Header />
  <main>
    <PageHero
      eyebrow="Desde Acapantzingo"
      title="Quiénes somos"
      description="Un equipo de profesionales de la comunicación humana y la psicología, trabajando bajo un mismo techo por el desarrollo de niñas, niños y adolescentes."
      crumbs={[{ label: 'Inicio', href: '/' }, { label: 'Quiénes somos' }]}
      variant="teal"
    />
    <Nosotros />
    <Enfoque />
    <CtaBand
      title="Conoce a fondo nuestro equipo"
      text="Dirección clínica, terapia de lenguaje y psicología infantil trabajando de forma coordinada en cada caso."
      ctaLabel="Ver al equipo"
      ctaHref="/equipo/"
    />
  </main>
  <Footer />
</Layout>
