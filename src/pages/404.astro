---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada — CDTI Cuernavaca">
  <Header />
  <main class="section-pad">
    <div class="wrap" style="text-align:center; padding: 60px 0;">
      <p class="eyebrow">Error 404</p>
      <h1 style="margin-top:12px; font-size:clamp(28px,4vw,44px); color:var(--teal-deep);">
        No encontramos esta página
      </h1>
      <p style="margin-top:16px; color:var(--ink-soft);">
        Puede que el enlace esté roto o la página haya cambiado de lugar.
      </p>
      <a href="/" class="btn btn-primary" style="margin-top:28px;">Volver al inicio</a>
    </div>
  </main>
  <Footer />
</Layout>
