---
interface Crumb { label: string; href?: string; }
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  crumbs: Crumb[];
  variant?: 'teal' | 'clay';
}
const { eyebrow, title, description, crumbs, variant = 'teal' } = Astro.props as Props;
---

<section class={`page-hero band-${variant}`}>
  <div class="wrap hero-inner">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      {crumbs.map((c, i) => (
        <>
          {i > 0 && <span class="sep">/</span>}
          {c.href ? <a href={c.href}>{c.label}</a> : <span class="current">{c.label}</span>}
        </>
      ))}
    </nav>

    {eyebrow && <p class="tag-pill">{eyebrow}</p>}
    <h1>{title}</h1>
    {description && <p class="hero-desc">{description}</p>}
  </div>

  <svg class="blob-deco" viewBox="0 0 400 400" aria-hidden="true">
    <path fill="rgba(255,248,239,0.12)" d="M200 16c80 0 156 40 172 116 14 68-30 110-72 156-44 48-66 96-140 96-78 0-148-44-168-116C-26 198-10 110 56 56 96 22 148 16 200 16Z"/>
  </svg>

  <svg class="page-divider" viewBox="0 0 1440 70" preserveAspectRatio="none" aria-hidden="true">
    <path fill="var(--paper)" d="M0,30 C240,70 420,0 680,24 C900,44 1040,8 1260,28 C1340,36 1400,22 1440,26 L1440,70 L0,70 Z"/>
  </svg>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: 38px 0 86px;
  }
  .breadcrumbs a, .breadcrumbs .sep, .breadcrumbs .current {
    color: rgba(255,248,239,0.85);
  }
  .breadcrumbs .current { color: #FFF8EF; }
  .tag-pill { margin-top: 16px; }
  h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.6vw, 50px);
    margin-top: 16px;
    color: #FFF8EF;
    max-width: 18ch;
  }
  .hero-desc {
    margin-top: 16px;
    max-width: 56ch;
    font-size: 17px;
    color: rgba(255,248,239,0.9);
  }
  .blob-deco {
    position: absolute;
    top: -120px;
    right: -100px;
    width: 360px;
    height: 360px;
    z-index: 0;
  }
  .hero-inner { position: relative; z-index: 1; }
  .page-divider {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    width: 100%;
    height: 60px;
  }
</style>
